# Public site URL (canonical / Open Graph). Set in GitHub Variables and Cloudflare Pages.
NEXT_PUBLIC_SITE_URL=https://localhost:3000

# Supabase → Project Settings → API (use anon key in the browser only).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Supabase Auth → add these URLs in the dashboard (Authentication → URL Configuration):
# - Site URL: same as NEXT_PUBLIC_SITE_URL
# - Redirect URLs: http://localhost:3000/**  and  https://YOUR_PRODUCTION_DOMAIN/**

# Database: SQL Editor → run migrations under supabase/migrations/, then optionally:
#   npm run generate:shop-seed
#   and run the generated supabase/seed_shop_products.sql to sync the catalog from code.
